#!/system/bin/sh
# Tool untuk cek sisa waktu sosmed - By Billy & Antigravity

TIME_FILE="/data/local/tmp/socmed_time.txt"
LIMIT=1800 # 30 menit (dalam detik)

if [ ! -f "$TIME_FILE" ]; then
    used=0
else
    used=$(cat "$TIME_FILE")
fi

# Validasi angka
if ! [ "$used" -eq "$used" ] 2>/dev/null; then
    used=0
fi

remaining=$((LIMIT - used))
if [ "$remaining" -lt 0 ]; then
    remaining=0
fi

used_min=$((used / 60))
used_sec=$((used % 60))
rem_min=$((remaining / 60))
rem_sec=$((remaining % 60))

# Definisikan warna ANSI
GREEN='\e[1;32m'
RED='\e[1;31m'
YELLOW='\e[1;33m'
CYAN='\e[1;36m'
NC='\e[0m' # No Color

echo -e "${CYAN}===========================================${NC}"
echo -e "${YELLOW}        🎯 REMINDER FOKUS TERMINAL 🎯      ${NC}"
echo -e "${CYAN}===========================================${NC}"
echo -e "Device  : POCO X3 Pro (vayu)"
echo -e "Limit   : 30 Menit / Hari (YouTube, IG, TikTok)"
echo -e "${CYAN}-------------------------------------------${NC}"
echo -e "Terpakai: ${YELLOW}${used_min} Menit ${used_sec} Detik${NC}"

if [ "$remaining" -gt 0 ]; then
    echo -e "Sisa    : ${GREEN}${rem_min} Menit ${rem_sec} Detik${NC} sebelum di-kill!"
    echo -e "Status  : ${GREEN}🟢 AKTIF (Silakan fokus!)${NC}"
else
    echo -e "Sisa    : ${RED}0 Detik (WAKTU HABIS!)${NC}"
    echo -e "Status  : ${RED}🔴 DIBLOKIR (Kembali ke terminal bro!)${NC}"
fi
echo -e "${CYAN}===========================================${NC}"
